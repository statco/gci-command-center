# gci-command-center — environment variables
# Copy to .env.local and fill in values (never commit real secrets).
# In production, set these in the Vercel project's Environment Variables.

# ── Walmart Canada Marketplace API ───────────────────────────────────────────
WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=

# ── Telegram notifications ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Shopify Admin API ────────────────────────────────────────────────────────
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_STORE_DOMAIN=

# ── Vercel KV (Storage → KV store → .env.local tab) ──────────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Google Analytics 4 (already used by existing code) ───────────────────────
GA4_CLIENT_ID=
GA4_CLIENT_SECRET=
GA4_REFRESH_TOKEN=
GA4_PROPERTY_ID=

# ── Xero (already used by existing code) ─────────────────────────────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REFRESH_TOKEN=
XERO_TENANT_ID=
